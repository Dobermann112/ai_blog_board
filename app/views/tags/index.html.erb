<h1 class="text-2xl font-bold mb-4 text-sky-800"><%= @page_title %></h1>

<% visible_tags, extra_tags = @tags.first(20), @tags.drop(20) %>

<ul class="flex flex-wrap gap-2">
  <% visible_tags.each do |tag| %>
    <li>
      <%= link_to "##{tag.name} (#{tag.posts.published.count})", tag_path(tag),
            class: "bg-white text-sky-700 border border-sky-200 rounded-full px-3 py-1 text-sm hover:bg-sky-50" %>
    </li>
  <% end %>
</ul>

<% if extra_tags.any? %>
  <details class="mt-3">
    <summary class="cursor-pointer text-sm text-sky-600">もっと見る（+<%= extra_tags.size %>）</summary>
    <ul class="flex flex-wrap gap-2 mt-2">
      <% extra_tags.each do |tag| %>
        <li>
          <%= link_to "##{tag.name} (#{tag.posts.published.count})", tag_path(tag),
                class: "bg-white text-sky-700 border border-sky-200 rounded-full px-3 py-1 text-sm hover:bg-sky-50" %>
        </li>
      <% end %>
    </ul>
  </details>
<% end %>
