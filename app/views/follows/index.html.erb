<div class="flex justify-between items-center mb-1">
  <h1 class="text-2xl font-bold text-sky-800"><%= @page_title %></h1>
</div>

<div class="flex flex-col gap-4">
  <% @users.each do |user| %>
    <div class="bg-white border border-sky-100 rounded-lg shadow-sm p-4 flex items-center justify-between gap-4">
      <%= link_to user.email, user_path(user), class: "text-sky-800 hover:text-sky-600 font-bold" %>
    </div>
  <% end %>
</div>

<%= render "posts/pagination", total_pages: @total_pages, current_page: @current_page %>
