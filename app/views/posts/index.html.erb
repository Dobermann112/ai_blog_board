<div class="flex justify-between items-center mb-1">
  <h1 class="text-2xl font-bold text-sky-800"><%= @page_title %></h1>
  <div class="flex items-center gap-2">
    <% if @user %>
      <%= render "posts/follow_button", user: @user %>
    <% end %>
    <% if user_signed_in? %>
      <%= link_to "新規投稿", new_post_path,
            class: "text-sm bg-sky-500 text-white rounded-md px-3 py-1.5 hover:bg-sky-600 transition" %>
    <% end %>
  </div>
</div>

<% if @page_subtitle %>
  <h2 class="text-sm text-slate-500 mb-4"><%= @page_subtitle %></h2>
<% end %>

<%= render "posts/post_list", posts: @posts %>

<%= render "posts/pagination", total_pages: @total_pages, current_page: @current_page %>
