<div class="bg-white border border-sky-100 rounded-lg shadow-sm p-6 flex flex-col gap-4">
  <div class="flex justify-between items-start gap-4">
    <h1 class="text-2xl font-bold text-sky-800"><%= @post.title %></h1>
    <%= render "posts/favorite_button", post: @post %>
  </div>

  <p class="text-sm text-slate-400">
    <%= @post.user.email %> ・ <%= l(@post.created_at, format: :long) %>
  </p>

  <% if @post.tags.any? %>
    <div class="flex flex-wrap gap-2 text-xs">
      <% @post.tags.each do |tag| %>
        <%= link_to "##{tag.name}", tag_path(tag),
              class: "bg-sky-50 text-sky-700 border border-sky-200 rounded-full px-2 py-0.5 hover:bg-sky-100" %>
      <% end %>
    </div>
  <% end %>

  <% if @post.image.attached? %>
    <%= image_tag @post.image, class: "max-w-full sm:max-w-md rounded-lg border border-sky-100" %>
  <% end %>

  <p class="whitespace-pre-wrap leading-relaxed"><%= @post.body %></p>

  <% if user_signed_in? && @post.user == current_user %>
    <div class="flex gap-2 pt-2 border-t border-sky-100">
      <%= link_to "編集", edit_post_path(@post),
            class: "text-sm bg-sky-100 text-sky-700 rounded-md px-3 py-1.5 hover:bg-sky-200 transition" %>
      <%= button_to "削除", post_path(@post), method: :delete, data: { turbo_confirm: "本当に削除しますか？" },
            class: "text-sm bg-rose-50 text-rose-600 border border-rose-200 rounded-md px-3 py-1.5 hover:bg-rose-100 transition" %>
    </div>
  <% end %>

  <%= link_to "← 記事一覧に戻る", posts_path, class: "text-sky-600 hover:text-sky-800 text-sm" %>
</div>
