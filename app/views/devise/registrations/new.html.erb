<h1 class="text-2xl font-bold mb-4 text-sky-800">会員登録</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name),
      html: { class: "bg-white border border-sky-100 rounded-lg shadow-sm p-6 flex flex-col gap-4 max-w-md" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="flex flex-col gap-1">
    <%= f.label :email, class: "text-sm font-bold text-sky-700" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :password, class: "text-sm font-bold text-sky-700" %>
    <% if @minimum_password_length %>
      <em class="text-xs text-slate-400">(<%= @minimum_password_length %>文字以上)</em>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :password_confirmation, class: "text-sm font-bold text-sky-700" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div>
    <%= f.submit "会員登録", class: "self-start bg-sky-500 text-white rounded-md px-4 py-2 hover:bg-sky-600 transition cursor-pointer" %>
  </div>
<% end %>

<div class="mt-4">
  <%= render "devise/shared/links" %>
</div>
