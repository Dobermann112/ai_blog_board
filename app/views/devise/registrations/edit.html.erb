<h1 class="text-2xl font-bold mb-4 text-sky-800">アカウント情報の編集</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put,
      class: "bg-white border border-sky-100 rounded-lg shadow-sm p-6 flex flex-col gap-4 max-w-md" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="flex flex-col gap-1">
    <%= f.label :email, class: "text-sm font-bold text-sky-700" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <div class="text-sm text-slate-500">確認待ちのメールアドレス: <%= resource.unconfirmed_email %></div>
  <% end %>

  <div class="flex flex-col gap-1">
    <%= f.label :password, class: "text-sm font-bold text-sky-700" %>
    <span class="text-xs text-slate-400">（変更しない場合は空欄のままにしてください）</span>
    <%= f.password_field :password, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
    <% if @minimum_password_length %>
      <em class="text-xs text-slate-400"><%= @minimum_password_length %>文字以上</em>
    <% end %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :password_confirmation, class: "text-sm font-bold text-sky-700" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :current_password, class: "text-sm font-bold text-sky-700" %>
    <span class="text-xs text-slate-400">（変更には現在のパスワードが必要です）</span>
    <%= f.password_field :current_password, autocomplete: "current-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div>
    <%= f.submit "更新", class: "self-start bg-sky-500 text-white rounded-md px-4 py-2 hover:bg-sky-600 transition cursor-pointer" %>
  </div>
<% end %>

<div class="mt-6 pt-4 border-t border-sky-100">
  <h2 class="font-bold text-rose-600 mb-2">アカウントの削除</h2>
  <div>
    <%= button_to "アカウントを削除する", registration_path(resource_name),
          data: { confirm: "本当に削除しますか？", turbo_confirm: "本当に削除しますか？" }, method: :delete,
          class: "text-sm bg-rose-50 text-rose-600 border border-rose-200 rounded-md px-3 py-1.5 hover:bg-rose-100 transition" %>
  </div>
</div>

<div class="mt-4">
  <%= link_to "← 戻る", :back, class: "text-sky-600 hover:text-sky-800 text-sm" %>
</div>
