<h1 class="text-2xl font-bold mb-4 text-sky-800">ログイン</h1>

<%= form_for(resource, as: resource_name, url: session_path(resource_name),
      html: { class: "bg-white border border-sky-100 rounded-lg shadow-sm p-6 flex flex-col gap-4 max-w-md" }) do |f| %>
  <div class="flex flex-col gap-1">
    <%= f.label :email, class: "text-sm font-bold text-sky-700" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :password, class: "text-sm font-bold text-sky-700" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center gap-2">
      <%= f.check_box :remember_me %>
      <%= f.label :remember_me, "ログイン状態を保存する", class: "text-sm text-slate-600" %>
    </div>
  <% end %>

  <div>
    <%= f.submit "ログイン", class: "self-start bg-sky-500 text-white rounded-md px-4 py-2 hover:bg-sky-600 transition cursor-pointer" %>
  </div>
<% end %>

<div class="mt-4">
  <%= render "devise/shared/links" %>
</div>
