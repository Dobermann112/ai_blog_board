<h1 class="text-2xl font-bold mb-4 text-sky-800">新しいパスワードの設定</h1>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put,
      class: "bg-white border border-sky-100 rounded-lg shadow-sm p-6 flex flex-col gap-4 max-w-md" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="flex flex-col gap-1">
    <%= f.label :password, "新しいパスワード", class: "text-sm font-bold text-sky-700" %>
    <% if @minimum_password_length %>
      <em class="text-xs text-slate-400">(<%= @minimum_password_length %>文字以上)</em>
    <% end %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div class="flex flex-col gap-1">
    <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "text-sm font-bold text-sky-700" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "border border-sky-200 rounded-md px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-sky-300" %>
  </div>

  <div>
    <%= f.submit "パスワードを変更する", class: "self-start bg-sky-500 text-white rounded-md px-4 py-2 hover:bg-sky-600 transition cursor-pointer" %>
  </div>
<% end %>

<div class="mt-4">
  <%= render "devise/shared/links" %>
</div>
